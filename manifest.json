{
  "manifest_version": 3,
  "name": "Mobile Vault",
  "version": "1.0.0",
  "description": "A secure browser extension for managing vault entries with encrypted credentials",
  "permissions": [
    "storage",
    "clipboardWrite",
    "activeTab"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mobile Vault - Click to open"
  },
  "icons": {
    "192": "icons/icon-192.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
