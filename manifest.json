{
  "manifest_version": 3,
  "name": "SecureVault",
  "version": "1.0.0",
  "description": "A secure browser extension for managing vault entries with encrypted credentials",
  "permissions": [
    "storage",
    "clipboardWrite"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SecureVault - Click to open"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
